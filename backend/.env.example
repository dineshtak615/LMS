NODE_ENV=development
PORT=5000

# Comma-separated list of allowed frontend origins
CLIENT_URL=http://localhost:3000

# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# JWT settings
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Razorpay test credentials (for demo account / test mode)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Optional: trust proxy hops when running behind reverse proxy/load balancer
# TRUST_PROXY=1

# Required for scripts/createSuperAdmin.js
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-this-strong-password
SUPER_ADMIN_NAME=Super Admin
